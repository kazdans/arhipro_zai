---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import services from '../data/services.json';
import { CONTACT } from '../config';
---

<BaseLayout
  title="Pakalpojumi"
  description="ARHITEKTONS piedāvā pilna cikla būvprojektēšanas pakalpojumus: projektēšanas uzdevums, būvprojektu izstrāde, apliecinājuma kartis, paskaidrojuma raksti, projektu vadība un autoruzraudzība."
>
  {/* Hero */}
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow reveal">Pakalpojumi</p>
      <h1 class="page-hero__title reveal">No pirmā uzdevuma<br /><em class="text-bronze">līdz pēdējam skrūvītim</em></h1>
      <p class="lead reveal">
        Pilna spektra arhitektūras un būvprojektēšanas pakalpojumi. Katrs posms rūpīgi izstrādāts,
        lai nodrošinātu tehnisku atbilstību, funkcionalitāti un estētisku vērtību.
      </p>
    </div>
  </section>

  {/* Quick nav chips */}
  <section class="services-nav">
    <div class="container">
      <div class="services-nav__inner reveal">
        {services.map((service) => (
          <a href={`#${service.id}`} class="chip">
            <span class="chip__num">{String(service.order).padStart(2, '0')}</span>
            {service.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Detailed services */}
  <section class="services-detail section--tight">
    <div class="container">
      {services.map((service, i) => (
        <article id={service.id} class="service-detail reveal">
          <div class="service-detail__side">
            <span class="service-detail__num">{String(service.order).padStart(2, '0')}</span>
            <span class="service-detail__icon">
              <Icon name={service.icon} size={32} />
            </span>
          </div>
          <div class="service-detail__body">
            <span class="service-detail__cat">{service.short}</span>
            <h2 class="service-detail__title">{service.title}</h2>
            <p class="service-detail__desc">{service.description}</p>

            <div class="service-detail__cols">
              <div class="service-detail__col">
                <h4 class="service-detail__heading">Ko mēs daram</h4>
                <ul class="service-detail__features">
                  {service.features.map((feature) => (
                    <li>
                      <Icon name="check" size={16} />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="service-detail__col">
                <h4 class="service-detail__heading">Rezultāts</h4>
                <p class="service-detail__deliverable">{service.deliverables}</p>
                <a href="/kontakti" class="service-detail__cta">
                  Pieprasīt piedāvājumu
                  <Icon name="arrow" size={16} />
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="cta-band section">
    <div class="container">
      <div class="cta-band__inner reveal">
        <div>
          <h2>Neatradāt, ko meklējāt?</h2>
          <p>Sazinieties ar mums — izvērtēsim jūsu vajadzības un piedāvāsim piemērotu risinājumu.</p>
        </div>
        <a href="/kontakti" class="btn btn--primary">
          Sazināties
          <Icon name="arrow" size={16} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: clamp(8rem, 14vw, 12rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--c-border-soft);
  }

  .page-hero__title {
    margin: 1.25rem 0 1.75rem;
  }

  .page-hero__title em {
    font-style: italic;
    font-weight: 400;
  }

  .services-nav {
    padding-block: 2.5rem;
    border-bottom: 1px solid var(--c-border-soft);
    background: var(--c-bg-elevated);
  }

  .services-nav__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.1rem;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border-soft);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--c-text-muted);
    transition: all var(--transition-base);
  }

  .chip:hover {
    border-color: var(--c-bronze);
    color: var(--c-bronze);
    background: rgba(201, 160, 99, 0.04);
  }

  .chip__num {
    font-family: var(--font-display);
    color: var(--c-bronze);
    font-size: 0.9rem;
  }

  /* Detail */
  .service-detail {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 3rem;
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-bottom: 1px solid var(--c-border-soft);
    scroll-margin-top: 120px;
  }

  .service-detail__side {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .service-detail__num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    color: var(--c-bronze);
    line-height: 1;
  }

  .service-detail__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border: 1px solid var(--c-bronze-deep);
    border-radius: var(--radius-md);
    color: var(--c-bronze);
  }

  .service-detail__cat {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-text-dim);
    margin-bottom: 0.75rem;
  }

  .service-detail__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }

  .service-detail__desc {
    color: var(--c-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 70ch;
  }

  .service-detail__cols {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border-soft);
  }

  .service-detail__heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-bronze);
    margin-bottom: 1.25rem;
  }

  .service-detail__features {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .service-detail__features li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--c-text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .service-detail__features svg {
    color: var(--c-bronze);
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .service-detail__deliverable {
    color: var(--c-text);
    font-size: 1rem;
    padding: 1rem 1.25rem;
    background: var(--c-bg-card);
    border-left: 2px solid var(--c-bronze);
    border-radius: var(--radius-sm);
    margin-bottom: 1.5rem;
  }

  .service-detail__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-bronze);
    transition: gap var(--transition-fast);
  }

  .service-detail__cta:hover {
    gap: 1rem;
  }

  /* CTA band */
  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(135deg, var(--c-bg-card), var(--c-bg-elevated));
    border: 1px solid var(--c-bronze-deep);
    border-radius: var(--radius-lg);
  }

  .cta-band h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 0.5rem;
  }

  .cta-band p {
    color: var(--c-text-muted);
  }

  @media (max-width: 900px) {
    .service-detail {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .service-detail__side {
      flex-direction: row;
      align-items: center;
    }
    .service-detail__cols {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .cta-band__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
