---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import projects from '../data/projects.json';

// Extract unique categories
const categories = [...new Set(projects.map((p) => p.category))];
const sortedProjects = [...projects].sort((a, b) => b.order - a.order);
---

<BaseLayout
  title="Projekti"
  description="ARHITEKTONS realizētie projekti — tūrisma infrastruktūra, publiskas ēkas, dzīvojamās ēkas, pārbūves un teritorijas labiekārtošana. Skatiet mūsu darbu portfeli."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow reveal">Projekti</p>
      <h1 class="page-hero__title reveal">Mūsu darbu<br /><em class="text-bronze">portfolio</em></h1>
      <p class="lead reveal">
        Vairāk nekā 500 realizētu projektu dažāda mēroga un kompleksitātes — no dabas taku izbūves
        līdz publiskām ēkām un dzīvojamo namu kompleksiem.
      </p>
    </div>
  </section>

  {/* Filter chips */}
  <section class="filters">
    <div class="container">
      <div class="filters__inner reveal">
        <button class="filter-chip is-active" data-filter="all">Visi ({projects.length})</button>
        {categories.map((cat) => {
          const count = projects.filter((p) => p.category === cat).length;
          return (
            <button class="filter-chip" data-filter={cat}>
              {cat} ({count})
            </button>
          );
        })}
      </div>
    </div>
  </section>

  {/* Projects grid */}
  <section class="projects-page section--tight">
    <div class="container">
      <div class="projects-page__grid">
        {sortedProjects.map((project, i) => (
          <article
            id={project.id}
            class={`project-card reveal ${project.featured ? 'project-card--featured' : ''}`}
            data-category={project.category}
            style={`transition-delay: ${i * 50}ms`}
          >
            <div class="project-card__visual">
              <div class="project-card__placeholder" data-category={project.category}>
                <Icon name="building" size={48} />
                <span class="project-card__year-badge">{project.year}</span>
              </div>
            </div>
            <div class="project-card__body">
              <div class="project-card__tags">
                <span class="tag tag--category">{project.category}</span>
                {project.featured && <span class="tag tag--featured">Izcilais</span>}
              </div>
              <h2 class="project-card__title">{project.title}</h2>
              <p class="project-card__desc">{project.description}</p>

              <div class="project-card__meta">
                <div class="meta-row">
                  <span class="meta-row__label">Atrašanās vieta</span>
                  <span class="meta-row__value">{project.location}</span>
                </div>
                <div class="meta-row">
                  <span class="meta-row__label">Pasūtītājs</span>
                  <span class="meta-row__value">{project.client}</span>
                </div>
                <div class="meta-row">
                  <span class="meta-row__label">Statuss</span>
                  <span class="meta-row__value text-bronze">{project.status}</span>
                </div>
              </div>

              <div class="project-card__scope">
                <h4>Darba apjoms</h4>
                <ul>
                  {project.scope.map((s) => (
                    <li><Icon name="check" size={14} /> {s}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .filters {
    padding-block: 2.5rem;
    border-bottom: 1px solid var(--c-border-soft);
    background: var(--c-bg-elevated);
  }

  .filters__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .filter-chip {
    padding: 0.7rem 1.2rem;
    background: var(--c-bg-card);
    border: 1px solid var(--c-border-soft);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--c-text-muted);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .filter-chip:hover {
    border-color: var(--c-bronze-deep);
    color: var(--c-text);
  }

  .filter-chip.is-active {
    background: var(--c-bronze);
    color: var(--c-bg);
    border-color: var(--c-bronze);
  }

  /* Projects grid */
  .projects-page__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    background: var(--c-bg-card);
    border: 1px solid var(--c-border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
    scroll-margin-top: 120px;
  }

  .project-card:hover {
    border-color: var(--c-bronze-deep);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }

  .project-card--featured {
    grid-column: span 2;
  }

  .project-card--featured .project-card__placeholder {
    min-height: 320px;
  }

  .project-card__visual {
    position: relative;
    overflow: hidden;
  }

  .project-card__placeholder {
    position: relative;
    min-height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, rgba(201, 160, 99, 0.08), rgba(138, 109, 62, 0.04)),
      var(--c-bg-elevated);
    color: var(--c-bronze);
    opacity: 0.5;
  }

  .project-card__placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201, 160, 99, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201, 160, 99, 0.08) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .project-card__year-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.4rem 0.85rem;
    background: rgba(10, 10, 11, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid var(--c-bronze-deep);
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--c-bronze);
  }

  .project-card__body {
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }

  .project-card__tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
  }

  .tag--category {
    background: rgba(201, 160, 99, 0.1);
    color: var(--c-bronze);
  }

  .tag--featured {
    background: var(--c-bronze);
    color: var(--c-bg);
  }

  .project-card__title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 0.85rem;
  }

  .project-card__desc {
    color: var(--c-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .project-card__meta {
    display: grid;
    gap: 0.85rem;
    padding: 1.5rem;
    background: var(--c-bg-elevated);
    border-radius: var(--radius-md);
    margin-bottom: 1.75rem;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .meta-row__label {
    color: var(--c-text-dim);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-row__value {
    color: var(--c-text);
    text-align: right;
    font-weight: 500;
  }

  .project-card__scope h4 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-bronze);
    margin-bottom: 1rem;
  }

  .project-card__scope ul {
    display: grid;
    gap: 0.6rem;
  }

  .project-card__scope li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--c-text-muted);
  }

  .project-card__scope svg {
    color: var(--c-bronze);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
    }
    .project-card--featured {
      grid-column: span 1;
    }
  }
</style>

<script>
  // Project filtering
  const chips = document.querySelectorAll('.filter-chip');
  const cards = document.querySelectorAll('.project-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const filter = chip.getAttribute('data-filter');
      chips.forEach((c) => c.classList.remove('is-active'));
      chip.classList.add('is-active');

      cards.forEach((card) => {
        const category = card.getAttribute('data-category');
        const show = filter === 'all' || category === filter;
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    });
  });
</script>
