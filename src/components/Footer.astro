---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { SITE, CONTACT, SOCIAL, FOOTER_NAV } from '../config';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__cta-band">
    <div class="container">
      <div class="footer__cta">
        <div>
          <p class="eyebrow">Sāksim kopā</p>
          <h2 class="footer__cta-title">Plānojat būvprojektu?<br />Runāsim par jūsu ideju.</h2>
        </div>
        <a href="/kontakti" class="btn btn--primary">
          Sazināties ar mums
          <Icon name="arrow" size={16} />
        </a>
      </div>
    </div>
  </div>

  <div class="footer__main">
    <div class="container">
      <div class="footer__grid">
        <div class="footer__col footer__brand">
          <Logo />
          <p class="footer__about">
            Arhitektūras un būvprojektēšanas birojs ar pilna cikla pakalpojumiem —
            no projektēšanas uzdevuma līdz autoruzraudzībai.
          </p>
          <a href={SOCIAL.facebook} target="_blank" rel="noopener" class="footer__social" aria-label="Facebook">
            <Icon name="facebook" size={18} />
          </a>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Pakalpojumi</h4>
          <ul>
            {FOOTER_NAV.pakalpojumi.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Uzņēmums</h4>
          <ul>
            {FOOTER_NAV.uznenums.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Kontakti</h4>
          <ul class="footer__contact">
            <li>
              <Icon name="location" size={16} />
              <span>{CONTACT.address}, {CONTACT.city}</span>
            </li>
            <li>
              <Icon name="phone" size={16} />
              <a href={CONTACT.phoneHref}>{CONTACT.phone}</a>
            </li>
            <li>
              <Icon name="mail" size={16} />
              <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
            </li>
            <li>
              <Icon name="clock" size={16} />
              <span>{CONTACT.hoursWeek}</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="footer__bottom">
        <p>© {year} {SITE.legalName}. Visas tiesības aizsargātas.</p>
        <p class="footer__meta">
          Izstrādāts ar <span class="text-bronze">Astro</span> · CMS <span class="text-bronze">Sveltia</span>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 2;
    background: var(--c-bg-elevated);
    border-top: 1px solid var(--c-border-soft);
  }

  .footer__cta-band {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--c-border-soft);
    background: linear-gradient(180deg, transparent, rgba(201, 160, 99, 0.03));
  }

  .footer__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__cta-title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    margin-top: 1rem;
  }

  .footer__main {
    padding-block: clamp(3.5rem, 7vw, 5rem) 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 3rem;
  }

  .footer__brand .logo {
    margin-bottom: 1.25rem;
  }

  .footer__about {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    line-height: 1.6;
    max-width: 36ch;
    margin-bottom: 1.5rem;
  }

  .footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--c-border);
    border-radius: 50%;
    color: var(--c-text-muted);
    transition: all var(--transition-base);
  }

  .footer__social:hover {
    border-color: var(--c-bronze);
    color: var(--c-bronze);
    transform: translateY(-2px);
  }

  .footer__heading {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-bronze);
    margin-bottom: 1.5rem;
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer__col a {
    font-size: 0.9rem;
    color: var(--c-text-muted);
    transition: color var(--transition-fast);
  }

  .footer__col a:hover {
    color: var(--c-bronze);
  }

  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--c-text-muted);
    font-size: 0.9rem;
  }

  .footer__contact svg {
    color: var(--c-bronze);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .footer__bottom {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border-soft);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--c-text-dim);
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
    .footer__cta {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
