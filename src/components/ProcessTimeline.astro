---
import Icon from './Icon.astro';

const steps = [
  {
    n: '01',
    title: 'Iepazīšanās un uzdevums',
    text: 'Sākam ar sarunu par jūsu vīziju, vajadzībām un budžetu. Sagatavojam projektēšanas uzdevumu — tehnisko pamatu tālākam darbam.',
  },
  {
    n: '02',
    title: 'Koncepcija un skices',
    text: 'Izstrādājam pirmās arhitektūras skices un funkcionalitātes risinājumus. Saskaņojam virzienu, pirms pārejam pie detalizētas izstrādes.',
  },
  {
    n: '03',
    title: 'Būvprojekta izstrāde',
    text: 'Veidojam pilnu būvprojektu — arhitektūru, konstrukcijas, inženierkomunikācijas. Veicam nepieciešamos aprēķinus un saskaņošanu.',
  },
  {
    n: '04',
    title: 'Saskaņošana un atļauja',
    text: 'Nodrošinām visu nepieciešamo dokumentu saskaņošanu ar būvvaldi un citām iestādēm, lai iegūtu būvatļauju.',
  },
  {
    n: '05',
    title: 'Autoruzraudzība',
    text: 'Pavadam projektu realizācijas laikā — uzraugām, ka būvniecība atbilst apstiprinātajam projektam un kvalitātes prasībām.',
  },
];
---

<section class="process section">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <p class="eyebrow eyebrow--center">Darba process</p>
      <h2>Kā mēs strādājam</h2>
      <p class="lead" style="margin-inline:auto;">
        Skaidrs, caurspīdīgs process piecos posmos — no pirmās sarunas līdz nodošanai ekspluatācijā.
      </p>
    </div>

    <div class="process-timeline">
      {steps.map((step, i) => (
        <div class="process-step reveal" style={`transition-delay: ${i * 80}ms`}>
          <div class="process-step__marker">
            <span class="process-step__num">{step.n}</span>
          </div>
          <div class="process-step__content">
            <h3 class="process-step__title">{step.title}</h3>
            <p class="process-step__text">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--c-bg-elevated);
    border-block: 1px solid var(--c-border-soft);
  }

  .process-timeline {
    position: relative;
    max-width: 880px;
    margin-inline: auto;
  }

  /* Vertical line */
  .process-timeline::before {
    content: '';
    position: absolute;
    left: 31px;
    top: 24px;
    bottom: 24px;
    width: 1px;
    background: linear-gradient(to bottom, var(--c-bronze), var(--c-border), transparent);
  }

  .process-step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 2rem;
    padding-bottom: 3rem;
    position: relative;
  }

  .process-step:last-child {
    padding-bottom: 0;
  }

  .process-step__marker {
    position: relative;
    z-index: 2;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--c-bg);
    border: 1px solid var(--c-bronze-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all var(--transition-base);
  }

  .process-step:hover .process-step__marker {
    border-color: var(--c-bronze);
    box-shadow: 0 0 0 8px rgba(201, 160, 99, 0.06);
  }

  .process-step__num {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--c-bronze);
  }

  .process-step__content {
    padding-top: 0.75rem;
  }

  .process-step__title {
    font-size: 1.4rem;
    margin-bottom: 0.6rem;
  }

  .process-step__text {
    color: var(--c-text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 60ch;
  }

  @media (max-width: 600px) {
    .process-step {
      grid-template-columns: 48px 1fr;
      gap: 1.25rem;
    }
    .process-step__marker {
      width: 48px;
      height: 48px;
    }
    .process-timeline::before {
      left: 23px;
    }
  }
</style>
