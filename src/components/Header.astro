---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { NAV, CONTACT } from '../config';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="header" id="site-header" data-header>
  <div class="header__inner container">
    <a href="/" class="header__logo" aria-label="ARHITEKTONS — sākumlapa">
      <Logo />
    </a>

    <nav class="header__nav" aria-label="Galvenā navigācija">
      <ul class="nav-list">
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__actions">
      <a href={CONTACT.phoneHref} class="header__phone" aria-label="Zvanīt">
        <Icon name="phone" size={16} />
        <span>{CONTACT.phone}</span>
      </a>
      <a href="/kontakti" class="btn btn--primary header__cta">Sazināties</a>
      <button class="header__toggle" id="menu-toggle" aria-label="Atvērt izvēlni" aria-expanded="false" aria-controls="mobile-menu">
        <Icon name="menu" size={24} class="icon-menu" />
        <Icon name="close" size={24} class="icon-close" />
      </button>
    </div>
  </div>

  {/* Mobile menu */}
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav class="mobile-menu__nav" aria-label="Mobilā navigācija">
      <ul>
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class={isActive(item.href) ? 'is-active' : ''}
            >
              {item.label}
              <Icon name="arrow-up-right" size={18} />
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mobile-menu__contact">
      <a href={CONTACT.phoneHref}>
        <Icon name="phone" size={18} />
        {CONTACT.phone}
      </a>
      <a href={`mailto:${CONTACT.email}`}>
        <Icon name="mail" size={18} />
        {CONTACT.email}
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: all var(--transition-base);
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    background: rgba(10, 10, 11, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: var(--c-border-soft);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 88px;
  }

  .header__logo {
    flex-shrink: 0;
  }

  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .nav-link {
    position: relative;
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
    transition: color var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 1px;
    background: var(--c-bronze);
    transition: width var(--transition-base);
  }

  .nav-link:hover,
  .nav-link.is-active {
    color: var(--c-text);
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    width: 24px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  .header__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c-text);
    transition: color var(--transition-fast);
  }

  .header__phone:hover {
    color: var(--c-bronze);
  }

  .header__cta {
    padding: 0.7rem 1.4rem;
    font-size: 0.75rem;
  }

  .header__toggle {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    color: var(--c-text);
  }

  .header__toggle .icon-close {
    display: none;
  }

  .header__toggle[aria-expanded='true'] .icon-menu {
    display: none;
  }

  .header__toggle[aria-expanded='true'] .icon-close {
    display: block;
  }

  /* ---------- Mobile menu ---------- */
  .mobile-menu {
    position: fixed;
    top: 88px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--c-bg-elevated);
    padding: 2rem 1.5rem;
    overflow-y: auto;
    z-index: 99;
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu__nav ul {
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__nav a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--c-text);
    border-bottom: 1px solid var(--c-border-soft);
    transition: color var(--transition-fast);
  }

  .mobile-menu__nav a:hover,
  .mobile-menu__nav a.is-active {
    color: var(--c-bronze);
  }

  .mobile-menu__contact {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu__contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--c-text-muted);
    font-size: 1rem;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1024px) {
    .header__nav,
    .header__phone {
      display: none;
    }
    .header__toggle {
      display: flex;
    }
    .header__inner {
      height: 72px;
    }
    .mobile-menu {
      top: 72px;
    }
  }

  @media (max-width: 640px) {
    .header__cta {
      display: none;
    }
  }
</style>

<script>
  // Scroll-based sticky styling
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 40);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
      document.body.style.overflow = '';
    };
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        closeMenu();
      } else {
        toggle.setAttribute('aria-expanded', 'true');
        menu.hidden = false;
        document.body.style.overflow = 'hidden';
      }
    });
    // Close on link click
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }
</script>
