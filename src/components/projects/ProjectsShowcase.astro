---
import Icon from '../Icon.astro';
import projects from '../../data/projects.json';

interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const featured = (limit ? projects.slice(0, limit) : projects.filter((p) => p.featured));
---

<section class="projects-showcase section">
  <div class="container">
    <div class="projects-header">
      <div class="section-header reveal" style="margin-bottom:0;">
        <p class="eyebrow">Mūsu darbi</p>
        <h2>Projekti, kas runā<br />pati par sevi</h2>
      </div>
      <a href="/projekti" class="projects-header__link reveal">
        Visi projekti
        <Icon name="arrow-up-right" size={18} />
      </a>
    </div>

    <div class="projects-list">
      {featured.map((project, i) => (
        <a href={`/projekti#${project.id}`} class={`project-row reveal`} style={`transition-delay: ${i * 60}ms`}>
          <div class="project-row__year">
            <span class="project-row__year-num">{project.year}</span>
          </div>
          <div class="project-row__main">
            <h3 class="project-row__title">{project.title}</h3>
            <span class="project-row__cat">{project.category}</span>
          </div>
          <div class="project-row__meta">
            <span class="project-row__location">
              <Icon name="location" size={14} />
              {project.location}
            </span>
          </div>
          <div class="project-row__arrow">
            <Icon name="arrow-up-right" size={22} />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .projects-header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--c-bronze);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: gap var(--transition-fast);
  }

  .projects-header__link:hover {
    gap: 0.85rem;
  }

  .projects-list {
    border-top: 1px solid var(--c-border);
  }

  .project-row {
    display: grid;
    grid-template-columns: 100px 1fr 200px 60px;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem 0.5rem;
    border-bottom: 1px solid var(--c-border);
    transition: all var(--transition-base);
    position: relative;
  }

  .project-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(201, 160, 99, 0.04), transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .project-row:hover::before {
    opacity: 1;
  }

  .project-row:hover {
    padding-left: 1.5rem;
  }

  .project-row__year {
    font-family: var(--font-display);
  }

  .project-row__year-num {
    font-size: 1.5rem;
    color: var(--c-bronze);
  }

  .project-row__title {
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    font-weight: 500;
    margin-bottom: 0.35rem;
    transition: color var(--transition-fast);
  }

  .project-row:hover .project-row__title {
    color: var(--c-bronze);
  }

  .project-row__cat {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    letter-spacing: 0.05em;
  }

  .project-row__location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--c-text-muted);
  }

  .project-row__arrow {
    display: flex;
    justify-content: flex-end;
    color: var(--c-text-dim);
    transition: all var(--transition-base);
  }

  .project-row:hover .project-row__arrow {
    color: var(--c-bronze);
    transform: translate(4px, -4px);
  }

  @media (max-width: 768px) {
    .project-row {
      grid-template-columns: auto 1fr auto;
      gap: 1rem;
    }
    .project-row__meta {
      display: none;
    }
  }
</style>
